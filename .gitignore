# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node.js dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Yarn
.yarn/*
!.yarn/cache
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
/coverage

# Next.js
/.next/
/out/

# Build output
/build

# Production
/build

# Static builds
/static

# Misc
.DS_Store
Thumbs.db
*.pem

# Local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Parcel-bundler cache (if using Parcel)
/.cache

# Logs
logs
*.log
*.log.*

# Editor directories and files
.vscode/*
.idea
*.sublime-project
*.sublime-workspace

# macOS Finder
.DS_Store

# Ignore node_modules inside any directory
**/node_modules
